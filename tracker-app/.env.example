# --- Client-side (bundled into browser JS via Vite) ---
# These are safe to expose — they use row-level security and public API keys.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_AUTH_REQUIRED=true

# Trigger.dev PUBLIC key (not the secret key!)
# VITE_TRIGGER_PUBLIC_KEY=tr_pub_XXXXXXXX

# --- Stripe ---
# Payment Links are configured directly in billing.ts (public checkout URLs).
# The Portal URL is optional — only needed for "Manage Subscription" button.
# VITE_STRIPE_PORTAL_URL=https://your-app.vercel.app/api/stripe/portal

# --- Server-side only (NEVER prefix with VITE_) ---
# Set these in Vercel/hosting environment variables, not in .env
# TRIGGER_SECRET_KEY=tr_dev_XXXXXXXX
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
