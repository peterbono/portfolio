# --- Client-side (bundled into browser JS via Vite) ---
# These are safe to expose — they use row-level security and public API keys.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_AUTH_REQUIRED=true

# Trigger.dev PUBLIC key (not the secret key!)
# VITE_TRIGGER_PUBLIC_KEY=tr_pub_XXXXXXXX

# --- Stripe ---
# Payment Links are configured directly in billing.ts (public checkout URLs).
# The Portal URL is optional — only needed for "Manage Subscription" button.
# VITE_STRIPE_PORTAL_URL=https://your-app.vercel.app/api/stripe/portal

# --- Server-side only (NEVER prefix with VITE_) ---
# Set these in Vercel/hosting environment variables, not in .env
# TRIGGER_SECRET_KEY=tr_dev_XXXXXXXX
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXX

# --- Stripe Server-Side (webhook + billing) ---
# Secret key from Stripe Dashboard → Developers → API keys
# STRIPE_SECRET_KEY=sk_live_XXXXXXXX
# Webhook signing secret from Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret
# STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXX

# --- Stripe Price ID → Plan Tier Mapping ---
# Set one env var per price. The webhook uses these to map Stripe prices to plan tiers.
# Get price IDs from Stripe Dashboard → Products → click product → price ID (price_xxx)
# STRIPE_PRICE_STARTER_WEEKLY=price_XXXXXXXX
# STRIPE_PRICE_STARTER_MONTHLY=price_XXXXXXXX
# STRIPE_PRICE_PRO_WEEKLY=price_XXXXXXXX
# STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXX
# STRIPE_PRICE_BOOST_WEEKLY=price_XXXXXXXX
# Alternative: JSON map of all prices → tiers (used if individual vars above are not set)
# STRIPE_PRICE_MAP={"price_xxx":"starter","price_yyy":"pro","price_zzz":"boost"}

